{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBedrockModels",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "arn:aws:bedrock:ap-northeast-1::foundation-model/amazon.titan-embed-text-v2:0",
        "arn:aws:bedrock:ap-northeast-1::foundation-model/anthropic.claude-3-5-sonnet-20241022-v2:0",
        "arn:aws:bedrock:ap-northeast-1::foundation-model/anthropic.claude-sonnet-4-5-20250929-v1:0",
        "arn:aws:bedrock:ap-northeast-1::foundation-model/anthropic.claude-sonnet-4-6"
      ]
    },
    {
      "Sid": "AllowReadManualBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1",
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/manuals/*",
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/summaries/*",
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/kb/*"
      ]
    },
    {
      "Sid": "AllowS3Vectors",
      "Effect": "Allow",
      "Action": [
        "s3vectors:*"
      ],
      "Resource": "*"
    }
  ]
}
