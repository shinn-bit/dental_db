{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManualBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/manuals/*",
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/metadata/*",
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/summaries/*",
        "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1/kb/*",
        "arn:aws:s3:::dental-manuals-ocr-dev-YOUR_ACCOUNT_ID-apne2/*"
      ]
    },
    {
      "Sid": "StartManualWorkflows",
      "Effect": "Allow",
      "Action": "states:StartExecution",
      "Resource": [
        "arn:aws:states:ap-northeast-1:YOUR_ACCOUNT_ID:stateMachine:dental-summary-worker-dev",
        "arn:aws:states:ap-northeast-1:YOUR_ACCOUNT_ID:stateMachine:dental-prepare-worker-dev"
      ]
    },
    {
      "Sid": "ListManualMetadata",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::dental-manuals-dev-YOUR_ACCOUNT_ID-apne1",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "metadata/*"
          ]
        }
      }
    },
    {
      "Sid": "BedrockKnowledgeBaseIngestion",
      "Effect": "Allow",
      "Action": [
        "bedrock:ListIngestionJobs",
        "bedrock:StartIngestionJob",
        "bedrock:GetIngestionJob"
      ],
      "Resource": "*"
    },
    {
      "Sid": "BedrockKnowledgeBaseChat",
      "Effect": "Allow",
      "Action": [
        "bedrock:RetrieveAndGenerate",
        "bedrock:Retrieve"
      ],
      "Resource": [
        "*",
        "arn:aws:bedrock:ap-northeast-1:YOUR_ACCOUNT_ID:knowledge-base/YOUR_KNOWLEDGE_BASE_ID"
      ]
    },
    {
      "Sid": "BedrockSummaryGeneration",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream",
        "bedrock:InvokeModel*"
      ],
      "Resource": [
        "arn:aws:bedrock:ap-northeast-1:YOUR_ACCOUNT_ID:inference-profile/jp.anthropic.claude-sonnet-4-6",
        "arn:aws:bedrock:ap-northeast-1::foundation-model/anthropic.claude-sonnet-4-6",
        "arn:aws:bedrock:ap-northeast-3::foundation-model/anthropic.claude-sonnet-4-6"
      ]
    },
    {
      "Sid": "BedrockInferenceProfileRead",
      "Effect": "Allow",
      "Action": [
        "bedrock:GetInferenceProfile"
      ],
      "Resource": [
        "arn:aws:bedrock:ap-northeast-1:YOUR_ACCOUNT_ID:inference-profile/jp.anthropic.claude-sonnet-4-6"
      ]
    },
    {
      "Sid": "TextractPdfOcr",
      "Effect": "Allow",
      "Action": [
        "textract:StartDocumentTextDetection",
        "textract:GetDocumentTextDetection"
      ],
      "Resource": "*"
    }
  ]
}
