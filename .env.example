# Local development only. Do not set AWS_PROFILE on Amplify/CI/service runtime.
AWS_PROFILE=dental-dev
APP_AWS_REGION=ap-northeast-1
APP_TEXTRACT_REGION=ap-northeast-2
S3_BUCKET_NAME=YOUR_S3_BUCKET_NAME
S3_MANUAL_PREFIX=manuals/
S3_METADATA_PREFIX=metadata/
APP_TEXTRACT_BUCKET_NAME=YOUR_TEXTRACT_BUCKET_NAME
APP_PREPARE_STATE_MACHINE_ARN=arn:aws:states:ap-northeast-1:YOUR_ACCOUNT_ID:stateMachine:YOUR_PREPARE_STATE_MACHINE_NAME
APP_SUMMARY_STATE_MACHINE_ARN=arn:aws:states:ap-northeast-1:YOUR_ACCOUNT_ID:stateMachine:YOUR_SUMMARY_STATE_MACHINE_NAME
PREPARE_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/YOUR_ACCOUNT_ID/YOUR_QUEUE_NAME
BEDROCK_KNOWLEDGE_BASE_ID=YOUR_KNOWLEDGE_BASE_ID
BEDROCK_DATA_SOURCE_ID=YOUR_DATA_SOURCE_ID
BEDROCK_MODEL_ARN=arn:aws:bedrock:ap-northeast-1:YOUR_ACCOUNT_ID:inference-profile/YOUR_MODEL_ID
APP_SHARE_PASSWORD=YOUR_SECURE_PASSWORD_HERE
APP_AUTH_SECRET=YOUR_LONG_RANDOM_SECRET_HERE
